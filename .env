# ─── Base de données ──────────────────────────────────────────────────────
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ─── Authentification ────────────────────────────────────────────────────
NEXTAUTH_SECRET=smartflow_ia_secret_key_2026_changez_en_production
NEXTAUTH_URL=http://localhost:3000

# ─── WhatsApp Cloud API (Meta) ──────────────────────────────────────────
# Obtenir ces tokens sur : https://developers.facebook.com/apps/
WHATSAPP_VERIFY_TOKEN=smartflow_verify_token
WHATSAPP_ACCESS_TOKEN=votre_access_token_meta
WHATSAPP_PHONE_NUMBER_ID=votre_phone_number_id

# ─── Telegram Bot ────────────────────────────────────────────────────────
# Créer un bot via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=votre_token_bot_telegram

# ─── Facebook Messenger ──────────────────────────────────────────────────
# Obtenir ces tokens sur : https://developers.facebook.com/apps/
MESSENGER_VERIFY_TOKEN=smartflow_verify_token
MESSENGER_PAGE_ACCESS_TOKEN=votre_page_access_token

# ─── Email (SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_mot_de_passe_app
SMTP_FROM=smartflow@votre-domaine.mg

# ─── Email rapport mensuel ───────────────────────────────────────────────
EMAIL_RAPPORT_DESTINATAIRE=admin@smartflow.mg

# ─── Cron ────────────────────────────────────────────────────────────────
# Mettre "true" pour activer le cron en développement
# CRON_ENABLED=true