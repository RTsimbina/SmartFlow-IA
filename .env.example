# ─── Base de données PostgreSQL ─────────────────────────────
# Obligatoire pour le déploiement Vercel (SQLite ne fonctionne pas sur Vercel)
# Utilisez Vercel Postgres, Neon, Supabase ou tout PostgreSQL compatible
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# ─── NextAuth ───────────────────────────────────────────────
# Généré avec : openssl rand -base64 32
NEXTAUTH_SECRET="votre-secret-nextauth-ici"
NEXTAUTH_URL="https://votre-domaine.vercel.app"

# ─── Google OAuth (optionnel) ───────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Setup Token (pour initialiser la BDD après déploiement) ─
# Généré avec : openssl rand -hex 16
# Appeler GET /api/setup?token=CE_TOKEN après le premier déploiement
SETUP_TOKEN="votre-token-setup-ici"

# ─── Email / SMTP (optionnel - pour les rapports mensuels) ──
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ─── WhatsApp Bot (optionnel) ───────────────────────────────
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_ACCESS_TOKEN=""

# ─── Telegram Bot (optionnel) ───────────────────────────────
TELEGRAM_BOT_TOKEN=""

# ─── Messenger Bot (optionnel) ──────────────────────────────
MESSENGER_VERIFY_TOKEN=""
MESSENGER_ACCESS_TOKEN=""

# ─── IA (LLM) ───────────────────────────────────────────────
# Requis pour l'Assistance IA et les bots
LLM_BASE_URL=https://votre-api-url.com/v1
LLM_API_KEY=votre-cle-api
LLM_MODEL=glm-4-flash

# ─── Cron (optionnel) ───────────────────────────────────────
# Activer le cron mensuel en production : true
CRON_ENABLED=""